# App timezone
TZ=Asia/Ho_Chi_Minh
PORT=3000

# Resend
RESEND_API_KEY=replace_with_resend_api_key
RESEND_FROM=Cham Cham <onboarding@resend.dev>
# Optional fallback recipient when using onboarding@resend.dev sandbox
RESEND_TEST_TO=

# SePay
SEPAY_MERCHANT_ID=replace_with_sepay_merchant_id
SEPAY_MERCHANT_SECRET_KEY=replace_with_sepay_merchant_secret
SEPAY_ENV=production
SEPAY_IPN_SECRET=replace_with_ipn_secret

# Waitlist email flow
WAITLIST_CHECKOUT_URL=https://your-domain.com/sepay_checkout.php
WAITLIST_WORKER_TOKEN=replace_with_worker_token

# Admin protection (optional but recommended)
ADMIN_USER=admin
ADMIN_PASS=change_this_password
